# Stripe sandbox integration only. Copy values into an untracked .env if needed.
AGENT_BOUNTY_STRIPE_SANDBOX=1
AGENT_BOUNTY_RUN_STRIPE_INTEGRATION=0
STRIPE_TEST_SECRET_KEY=sk_test_placeholder
STRIPE_TEST_WEBHOOK_SECRET=whsec_placeholder
STRIPE_TEST_CONNECTED_ACCOUNT_ID=acct_placeholder
STRIPE_TEST_PLATFORM_ACCOUNT_ID=

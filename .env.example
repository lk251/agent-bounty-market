# Optional GitHub live integration. Keep real values only in untracked .env or
# secret storage. Do not commit tokens or webhook secrets.
AGENT_BOUNTY_GITHUB_INTEGRATION=0
AGENT_BOUNTY_GITHUB_TRANSPORT=development-token
AGENT_BOUNTY_GITHUB_REPOSITORY=lk251/motoko
AGENT_BOUNTY_GITHUB_TOKEN=
AGENT_BOUNTY_GITHUB_WEBHOOK_SECRET=
AGENT_BOUNTY_GITHUB_INSTALLATION_ID=
